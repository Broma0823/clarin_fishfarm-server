%%{init: {
%%  "theme": "base",
%%  "themeVariables": {
%%    "background": "#ffffff",
%%    "primaryColor": "#ffffff",
%%    "primaryTextColor": "#000000",
%%    "primaryBorderColor": "#000000",
%%    "lineColor": "#000000",
%%    "clusterBkg": "#ffffff",
%%    "clusterBorder": "#000000"
%%  }
%%}}%%
flowchart TB
    %% ---------- User ----------
    USER["User<br/>(Laptop / Mobile<br/>Browser)"]

    %% ---------- Server Layer ----------
    subgraph SERVER["Raspberry Pi Server"]
        direction TB
        WEB["React Frontend<br/>(:5173)"]
        API["Express API<br/>(:4000)"]
        DB[("PostgreSQL<br/>(bfar_db)")]
        WEB -->|"GET/POST"| API
        API -->|"JSON"| WEB
        API -->|"Read/Write"| DB
        DB -->|"Results"| API
    end

    %% ---------- Network ----------
    NET["Wi-Fi<br/>Network"]

    %% ---------- Field Layer ----------
    subgraph FIELD["Pond / Sensor Layer"]
        direction TB
        T["Water Temp Sensor<br/>(DS18B20)"]
        PH["pH Sensor<br/>Probe"]
        DO["Dissolved Oxygen Sensor<br/>Probe"]
        ESP["ESP32<br/>Controller"]
        T --> ESP
        PH --> ESP
        DO --> ESP
    end

    %% ---------- Main vertical flow ----------
    USER -->|"Open dashboard"| WEB
    API --> NET
    NET -->|"POST /api/monitoring (every 60s)"| ESP

    %% ---------- Monochrome styling ----------
    classDef sensor fill:#ffffff,stroke:#000000,stroke-width:1px,color:#000000;
    classDef service fill:#ffffff,stroke:#000000,stroke-width:1px,color:#000000;
    classDef network fill:#ffffff,stroke:#000000,stroke-width:1px,color:#000000;
    classDef user fill:#ffffff,stroke:#000000,stroke-width:1px,color:#000000;
    classDef database fill:#ffffff,stroke:#000000,stroke-width:1px,color:#000000;

    class T,PH,DO,ESP sensor
    class WEB,API service
    class NET network
    class USER user
    class DB database
    style FIELD fill:#ffffff,stroke:#000000,stroke-width:1px,color:#000000
    style SERVER fill:#ffffff,stroke:#000000,stroke-width:1px,color:#000000
